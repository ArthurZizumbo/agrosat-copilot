# ─────────────────────────────────────────────────────────────────────────────
# AgroSatCopilot — environment template (copy to .env.local; never commit)
# ─────────────────────────────────────────────────────────────────────────────

# === General ===
ENV=dev                                   # dev (único entorno activo, ver ADR-002)
LOG_LEVEL=INFO
APP_NAME=agrosatcopilot
DEBUG=false

# === Host ports ===
# Defaults canónicos. Si alguno choca con otro stack Docker local, sobrescribe
# SOLO en tu .env.local (gitignored) — no edites este archivo con los puertos
# reales de tu máquina. Los puertos internos del contenedor son fijos.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
API_HOST_PORT=8000
FRONTEND_HOST_PORT=3000
TITILER_HOST_PORT=8001
MLFLOW_HOST_PORT=5000
DAGSTER_HOST_PORT=3001
OLLAMA_HOST_PORT=11434

# === Database ===
# Host-side resuelve POSTGRES_HOST_PORT; servicios dentro de docker resuelven
# `postgres:5432` por DNS interno — no usar localhost desde otros contenedores.
DATABASE_URL=postgresql+asyncpg://agrosat:agrosat@localhost:5432/agrosat
DBMATE_DATABASE_URL=postgres://agrosat:agrosat@localhost:5432/agrosat?sslmode=disable

# === Redis ===
# Dev local: docker-compose redis:7-alpine via REDIS_URL.
# Cloud: Upstash Redis serverless (ADR-003) via UPSTASH_REDIS_REST_*.
# Backend resuelve UPSTASH_* si estan definidos; si no, cae a REDIS_URL.
REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === GCP ===
GCP_PROJECT_ID=agrosat-prod
GCP_REGION=europe-west1
GOOGLE_APPLICATION_CREDENTIALS=./.env/gcp-service-account.json
GCS_DATA_BUCKET=agrosat-data
GCS_ARTIFACTS_BUCKET=agrosat-artifacts
GCS_DVC_BUCKET=agrosat-dvc-remote
PUBSUB_INFERENCE_TOPIC=inference-jobs

# === Azure (H100 only) ===
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=agrosat-rg
AZURE_H100_VM_NAME=agrosat-h100-prod
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CHECKPOINTS_CONTAINER=agrosat-checkpoints

# === Google Earth Engine ===
GEE_SERVICE_ACCOUNT_PATH=./.env/gee-service-account.json
GEE_PROJECT_ID=agrosat-prod

# === Copernicus Data Space Ecosystem (Sentinel) ===
CDSE_USERNAME=
CDSE_PASSWORD=

# === HuggingFace ===
HUGGINGFACE_TOKEN=
HF_HOME=~/.cache/huggingface

# === LLM Backends ===
LLM_VARIANT_DEFAULT=gemini                # gemini | qwen35
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-3.1-pro
VLLM_QWEN35_URL=http://vllm-qwen35.internal:8000/v1
VLLM_API_KEY=not-needed

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_STORE=gs://agrosat-artifacts/mlflow/

# === Dagster ===
DAGSTER_HOME=./dagster_home

# === Auth (Clerk) ===
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# === Frontend ===
FRONTEND_URL=http://localhost:3000
NUXT_PUBLIC_API_URL=http://localhost:8000

# === Observability ===
PROMETHEUS_PUSHGATEWAY=
SENTRY_DSN=

# === Auth / Security ===
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_CHAT_PER_MIN=10
RATE_LIMIT_LLM_SWITCH_PER_MIN=5

# === Terraform / Cloud Build (cuando se despliega) ===
TF_VAR_project_id=agrosat-prod
TF_VAR_gcp_region=europe-west1
TF_VAR_azure_location=westeurope
# PLACEHOLDER no-op (0.0.0.0/32 = ningun host). Sustituir SOLO en .env.local
# con los CIDRs reales de los 3 devs antes de `terraform apply` Azure.
# NUNCA usar 0.0.0.0/0 — el NSG abriria SSH al mundo.
TF_VAR_allowed_ssh_cidrs=["0.0.0.0/32"]

# === DVC remote (sólo si se configura local) ===
DVC_REMOTE_NAME=gcs
DVC_REMOTE_URL=gs://agrosat-dvc-remote
