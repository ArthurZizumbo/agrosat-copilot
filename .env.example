# ─────────────────────────────────────────────────────────────────────────────
# AgroSatCopilot — environment template (copy to .env.local; never commit)
# ─────────────────────────────────────────────────────────────────────────────

# === General ===
ENV=dev                                   # dev | staging | prod
LOG_LEVEL=INFO

# === Database ===
DATABASE_URL=postgresql+asyncpg://agrosat:agrosat@localhost:5432/agrosat
DBMATE_DATABASE_URL=postgres://agrosat:agrosat@localhost:5432/agrosat?sslmode=disable

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === GCP ===
GCP_PROJECT_ID=agrosat-prod
GCP_REGION=europe-west1
GOOGLE_APPLICATION_CREDENTIALS=./.env/gcp-service-account.json
GCS_DATA_BUCKET=agrosat-data
GCS_ARTIFACTS_BUCKET=agrosat-artifacts
GCS_DVC_BUCKET=agrosat-dvc-remote
PUBSUB_INFERENCE_TOPIC=inference-jobs

# === Azure (H100 only) ===
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=agrosat-rg
AZURE_H100_VM_NAME=agrosat-h100-prod
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CHECKPOINTS_CONTAINER=agrosat-checkpoints

# === Google Earth Engine ===
GEE_SERVICE_ACCOUNT_PATH=./.env/gee-service-account.json
GEE_PROJECT_ID=agrosat-prod

# === Copernicus Data Space Ecosystem (Sentinel) ===
CDSE_USERNAME=
CDSE_PASSWORD=

# === HuggingFace ===
HUGGINGFACE_TOKEN=
HF_HOME=~/.cache/huggingface

# === LLM Backends ===
LLM_VARIANT_DEFAULT=gemini                # gemini | qwen35
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-3.1-pro
VLLM_QWEN35_URL=http://vllm-qwen35.internal:8000/v1
VLLM_API_KEY=not-needed

# === MLflow ===
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_STORE=gs://agrosat-artifacts/mlflow/

# === Dagster ===
DAGSTER_HOME=./dagster_home

# === Auth (Clerk) ===
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# === Frontend ===
FRONTEND_URL=http://localhost:3000
NUXT_PUBLIC_API_URL=http://localhost:8000

# === Observability ===
PROMETHEUS_PUSHGATEWAY=
SENTRY_DSN=
