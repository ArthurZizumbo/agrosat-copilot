{
  "name": "agrosatcopilot-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3000",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --ext .vue,.ts,.tsx",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "i18n:check": "node ../scripts/i18n_check.mjs"
  },
  "dependencies": {
    "@ai-sdk/vue": "^3.0.180",
    "@nuxt/ui-pro": "^3.3.7",
    "@nuxtjs/i18n": "^10.3.0",
    "@pinia/nuxt": "^0.11.3",
    "deck.gl": "^9.3.2",
    "maplibre-gl": "^5.24.0",
    "nuxt": "^4.4.5",
    "pinia": "^3.0.4",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.7.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.16.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.8"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.24.0",
