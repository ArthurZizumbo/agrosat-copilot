!backend/tests/fixtures/**/*.parquet
!ml/tests/fixtures/**/*.parquet

# ── Notebooks: strip outputs but keep .ipynb files ────────────────────────────
# nbstripout se ejecuta en CI (`make notebooks-strip`) — large outputs out of git
notebooks/*.html
notebooks/.virtual_documents/
notebooks/_export/

# ── Media / large binaries ────────────────────────────────────────────────────
*.jpg
*.jpeg
*.png
*.gif
*.mp4
*.mov
*.avi
*.pdf
*.zip
*.tar.gz
*.tar
*.7z
# Exceptions for frontend & docs assets
!frontend/public/icons/*.png
!frontend/public/images/*.png
!frontend/public/images/*.jpg
!frontend/assets/**/*.png
!frontend/assets/**/*.svg
!docs/architecture/*.png
!docs/architecture/*.svg
!paper/figures/*.pdf
!paper/figures/*.png

# Context & academic PDFs needed for reference
!context/*.pdf

# ── docs/general: solo se versiona la rúbrica oficial del curso ──────────────
# Resto (planteamientos personales, PDFs de avances, papers de referencia,
# .docx con comentarios) queda fuera del repo. La rúbrica sí porque está
# referenciada desde AGENTS.md / CLAUDE.md / skills / notebooks.
docs/general/*
!docs/general/Rubricas Integrador.html

