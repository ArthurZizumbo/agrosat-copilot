*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Engram (local dev-time memory, never commit DB or local cache) ────────────
.engram/
*.engram.db
*.engram.db-wal
*.engram.db-shm
.engram-export/
# Sí se trackean chunks exportados y revisados:
!docs/engram/*.engram

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── DVC (data version control) ────────────────────────────────────────────────
# Track DVC config but never raw data
data/raw/**
data/processed/**
data/interim/**
data/external/**
data/cache/**
# Raw datasets locales (PASTIS-R, Dynamic World subsets, GSAA, etc.) — fuera del repo
# Se versionan vía DVC cuando se cierre US-006/US-007/US-008. Hasta entonces, viven
# solo en la máquina de Isaac y se documentan en data/README.md.
data/PASTIS-R/
data/dynamic_world/
data/gsaa_italia/
data/reference/spectral_library.parquet
!data/.gitkeep
!data/README.md
!data/example/*.geojson
/data/example/*.tif
# DVC metadata files (.dvc) MUST be tracked — they point to remote
!*.dvc
.dvc/cache/
.dvc/tmp/
.dvc/plots/
.dvc/config.local

# ── MLflow ────────────────────────────────────────────────────────────────────
mlruns/
mlflow.db
mlartifacts/

# ── Dagster ───────────────────────────────────────────────────────────────────
dagster_project/.dagster/
dagster_home/
$DAGSTER_HOME/
tmp_dagster_home_*/
schedules/
storage/
history/
compute_logs/

